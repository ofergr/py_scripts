EMAIL_SERVICE=gmail
SENDER_EMAIL=#sender email
SENDER_PASSWORD=#your 16 letters GMAIL APP password
RECIPIENTS=#comma seperated list of recipients
FINNHUB_IO_API_KEY=#your finnhub API KEY (also used for news enrichment)

# Logo.dev API token (optional - get free token at https://www.logo.dev/)
# Free tier: 500,000 requests/month with attribution
LOGO_DEV_TOKEN=#your PUBLISHABLE API KEY (not the secret one)

# Groq AI (recommended - free tier, takes priority over Ollama)
# Get your free API key at https://console.groq.com (no credit card required)
# Free tier: 30 RPM, 14,400 requests/day — more than enough for daily use
GROQ_API_KEY=#your Groq API key (starts with gsk_...)
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (local fallback - used only when GEMINI_API_KEY is not set)
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434

